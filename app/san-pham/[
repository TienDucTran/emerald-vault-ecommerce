import { notFound } from 'next/navigation';
import Link from 'next/link';
import { ChevronRight } from 'lucide-react';
import { getProductBySlug, MOCK_PRODUCTS } from '@/lib/mock-data';
import { CATEGORY_LABELS } from '@/lib/utils';
import { ProductGallery } from '@/components/product/product-gallery';
import { ProductInfoPanel } from '@/components/product/product-info-panel';
import { StorytellingSection } from '@/components/product/storytelling-section';
import { DetailsAccordion } from '@/components/product/details-accordion';
import { RecentlyViewed } from '@/components/product/recently-viewed';
import { ProductGrid } from '@/components/product/product-grid';

interface Props {
  params: { slug: string };
}

export default function ProductDetailPage({ params }: Props) {
  const product = getProductBySlug(params.slug);
  if (!product) notFound();

  // Related products — same category, exclude current, limit 4
  const related = MOCK_PRODUCTS
    .filter(
      (p) =>
        p.id !== product.id &&
        p.status === 'AVAILABLE' &&
        p.category === product.category
    )
    .slice(0, 4);

  // Recently viewed — mock: take some other products
  const recentlyViewed = MOCK_PRODUCTS.filter((p) => p.id !== product.id).slice(
    0,
    6
  );

  return (
    <div className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      {/* Breadcrumb — Cinzel uppercase */}
      <nav className="mb-8 flex items-center gap-2 text-xs uppercase tracking-widest text-text-muted opacity-60">
        <Link href="/" className="font-heading transition-colors hover:text-gold">
          TRANG CHỦ
        </Link>
        <ChevronRight className="h-3 w-3" />
        <Link
          href={`/san-pham?category=${product.category}`}
          className="font-heading transition-colors hover:text-gold"
        >
          {CATEGORY_LABELS[product.category].toUpperCase()}
        </Link>
        <ChevronRight className="h-3 w-3" />
        <span className="font-heading text-gold">
          {product.title.toUpperCase()}
        </span>
      </nav>

      {/* Top section: Gallery + Info — two columns */}
      <div className="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <ProductGallery product={product} />
        <ProductInfoPanel product={product} />
      </div>

      {/* Storytelling section */}
      <StorytellingSection product={product} />

      {/* Details accordion */}
      <DetailsAccordion product={product} />

      {/* Recommendations */}
      {related.length > 0 && (
        <section className="pt-12">
          <h2 className="mb-8 border-l-4 border-gold pl-6 font-heading text-2xl font-bold text-text-base sm:text-3xl">
            BẠN CÓ THỂ THÍCH
          </h2>
          <ProductGrid products={related} columns={4} />
        </section>
      )}

      {/* Recently viewed */}
      <RecentlyViewed products={recentlyViewed} currentId={product.id} />
    </div>
  );
}