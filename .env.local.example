# ===========================================
# AI Chatbot & Embedding — Free Providers
# Emerald Vault Ecommerce
# ===========================================
# Set CHAT_PROVIDERS (CSV) để pin thứ tự ưu tiên.
# Nếu rỗng → auto-fallback: groq → openrouter → cerebras → cloudflare → gemini → openai
# Format: "<provider>:<modelName>"

# Chat chain ưu tiên (khuyến nghị cho free + ổn định):
CHAT_PROVIDERS="groq:llama-3.1-8b-instant,openrouter:meta-llama/llama-3.3-70b:free,cerebras:llama-3.3-70b,gemini:gemini-2.0-flash"

# Embedding chain (Gemini đang fail ở paid tier → dùng openrouter free):
# Set EMBED_PRIMARY=openrouter để ưu tiên OpenRouter embedding trước.
EMBED_PRIMARY=openrouter

# ===========================================
# Provider 1: GROQ (FREE — khuyến nghị #1)
# ===========================================
# Free tier: 30 req/min, 14,400 req/day. Rất nhanh.
# Đăng ký: https://console.groq.com/keys
GROQ_API_KEY=

# ===========================================
# Provider 2: OPENROUTER (FREE — nhiều model)
# ===========================================
# Free tier: 20 req/min cho model :free suffix. Tương thích OpenAI API.
# Đăng ký: https://openrouter.ai/keys
# Models free tốt:
#   - meta-llama/llama-3.3-70b:free
#   - qwen/qwen-2.5-72b-instruct:free
#   - google/gemini-2.0-flash-exp:free
OPENROUTER_API_KEY=

# ===========================================
# Provider 3: CEREBRAS (FREE — nhanh nhất thế giới)
# ===========================================
# Free tier: 30 req/min, inference ~2000 tokens/sec.
# Đăng ký: https://cloud.cerebras.ai/ (Sign in → API Keys)
# Models: llama-3.3-70b, llama-3.1-8b, qwen-2.5-72b
CEREBRAS_API_KEY=

# ===========================================
# Provider 4: CLOUDFLARE WORKERS AI (FREE)
# ===========================================
# Free tier: 10,000 neurons/day. Cần cả API key + Account ID.
# Lấy Account ID: https://dash.cloudflare.com/ → Workers & Pages → Overview (góc phải)
# Lấy API key: https://dash.cloudflare.com/profile/api-tokens → Create Token → Edit Cloudflare Workers
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# ===========================================
# Provider 5: GOOGLE AI STUDIO (FREE — có giới hạn)
# ===========================================
# Free tier: 15 req/min, 1M tokens/day cho gemini-2.0-flash.
# Embedding gemini-embedding-001: 1500 req/day, NHƯNG chỉ free nếu KHÔNG enable billing.
# Lưu ý: Nếu đã lỡ bật billing và hết credit, dùng OPENROUTER_API_KEY thay thế.
# Đăng ký: https://aistudio.google.com/apikey (QUAN TRỌNG: đừng click "Enable billing")
GOOGLE_AI_API_KEY=

# ===========================================
# Provider 6: OPENAI (PAID — fallback cuối)
# ===========================================
# gpt-4o-mini: $0.15/1M input tokens. Chỉ dùng nếu các free provider trên đều fail.
# Đăng ký: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# Site URL (dùng cho OpenRouter header HTTP-Referer)
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
